{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage",
  "version": "0.1.0",
  "identifier": "com.eduardocampos.claude-usage",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:8090"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage",
        "url": "http://localhost:8090/widget?layout=horizontal&native=1",
        "width": 504,
        "height": 268,
        "minWidth": 380,
        "minHeight": 190,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
